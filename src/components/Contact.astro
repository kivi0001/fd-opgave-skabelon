---
import { Image } from "astro:assets";

import contact from "@assets/images/empoyees-contact.jpg";
import img from "@assets/images/Image.png";
import Photo from "@assets/images/Photo.jpg";

import Phone from "@icons/phone.svg";
import Clock from "@icons/clock.svg";
import Pin from "@icons/pin.svg";
---

<section>
  <div class="container">
    <div class="empoyeesImg">
      <Image src={img} alt="CEO" width={600} height={800} class="img-main" />

      <Image
        src={contact}
        alt="CEO"
        width={400}
        height={400}
        class="img-bottom"
      />

      <Image src={Photo} alt="CEO" width={400} height={400} class="img-top" />
    </div>

    <div class="content">
      <p>Process</p>
      <h2>Contact Us. It’s Easy.</h2>

      <p>
        Leverage agile frameworks to provide a robust synopsis for high level
        overviews. Iterative approaches to corporate strategy foster
        collaborative.
      </p>

      <ul class="ul-Expect">
        <li>
          <Phone color="#DEAA27" class="my-icon phone" />
          <div><p>Call Today</p> <p>+1 800 100 900</p></div>
        </li>
        <li>
          <Clock color="#4EAF4E" class="my-icon clock" />
          <div><p>Monday To Friday</p> <p>9AM - 5PM</p></div>
        </li>
        <li>
          <Pin color="black" class="my-icon pin" />
          <div><p>USA Office</p> <p>195 Devonshire St Boston, MA 02110</p></div>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  @layer components {
    .container {
      display: grid;
      grid-template-columns: 1fr 450px;
      grid-template-areas: "content images";
      gap: 2rem;
      align-items: center;
    }

    .content {
      grid-area: content;
    }

    .empoyeesImg {
      grid-area: images;
    }

    @media (max-width: 868px) {
      .container {
        grid-template-columns: 1fr;
        grid-template-areas:
          "images"
          "content";
      }

      .empoyeesImg::before {
        top: 60%;
        left: -1rem;
        width: 200px;
        height: 120px;
      }
    }

    .empoyeesImg {
      display: grid;
      grid-template-columns: 2fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 1rem;

      position: relative;
      isolation: isolate;
    }

    .empoyeesImg::before {
      content: "";
      position: absolute;
      top: 22rem;
      left: -2rem;
      background: var(--color-ui-secondary);
      width: 281px;
      height: 150px;
      border-radius: 20px;
      z-index: -1;
    }

    .empoyeesImg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: var(--border-image);
    }

    .img-main {
      grid-row: 1 / 3;
      grid-column: 1;
    }

    .img-top {
      grid-row: 1;
      grid-column: 2;
    }

    .img-bottom {
      grid-row: 2;
      grid-column: 2;
    }

    /* ===== Content ===== */

    h2 {
      font-size: xx-large;
      font-family: var(--font-heading);
    }

    p:has(+ h2) {
      color: var(--color-text);
      line-height: var(--space-xl);
    }

    /* ===== Contact List ===== */

    .ul-Expect {
      display: grid;
      gap: 1.5rem;
      padding: 0;
    }

    .ul-Expect li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 1rem;
      align-items: start;
      font-size: 1rem;
    }

    .my-icon {
      width: 30px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--border-icon);
    }
    .my-icon svg {
      width: 100%;
      height: 100%;
    }
    .phone {
      border: 5px solid #ffecbb;
      background-color: #ffecbb;
    }
    .clock {
      border: 5px solid #a4eda4;
      background-color: #a4eda4;
      border-radius: 1rem;
    }
    .pin {
      border: 4px solid #eaeaea;
      background-color: #eaeaea;
    }
  }
</style>
