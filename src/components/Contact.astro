---
import { Image } from "astro:assets";

import contact from "@assets/images/empoyees-contact.jpg";
import img from "@assets/images/Image.png";
import Photo from "@assets/images/Photo.jpg";

import Phone from "@icons/phone.svg";
import Clock from "@icons/clock.svg";
import Pin from "@icons/pin.svg";
---

<section>
  <div class="container">
    <div class="content">
      <p class="title">Process</p>
      <h2>Contact Us. It’s Easy.</h2>

      <p>
        Leverage agile frameworks to provide a robust synopsis for high level
        overviews. Iterative approaches to corporate strategy foster
        collaborative.
      </p>

      <ul class="ul-Expect">
        <li>
          <div class="phone">
            <Phone class="my-icon" />
          </div>
          <div>
            <p>Call Today</p>
            <p class="p-color">+1 800 100 900</p>
          </div>
        </li>

        <li>
          <div class="clock">
            <Clock class="my-icon" />
          </div>

          <div>
            <p>Monday To Friday</p>
            <p class="p-color">9AM - 5PM</p>
          </div>
        </li>

        <li>
          <div class="pin">
            <Pin class="my-icon" />
          </div>
          <div>
            <p>USA Office</p>
            <p class="p-color">195 Devonshire St Boston, MA 02110</p>
          </div>
        </li>
      </ul>
    </div>

    <div class="empoyeesImg">
      <div class="green">
        <Image src={img} alt="CEO" />
      </div>

      <Image src={Photo} alt="CEO" class="img-top" />

      <Image src={contact} alt="CEO" class="img-bottom" />
    </div>
  </div>
</section>

<style>
  @layer components {
    section {
      padding: var(--section-spacing-l);
    }

    .container {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 3rem;
      align-items: stretch;
      padding-block: var(--space-l);
    }

    .content {
      min-width: 290px;
    }

    /* IMAGE GRID */

    .empoyeesImg {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 1rem;
      height: 100%;
    }

    .empoyeesImg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .green {
      height: 100%;
      grid-row: 1 / 3;
      position: relative;
      isolation: isolate;
    }

    .green::before {
      content: "";
      position: absolute;
      bottom: -2rem;
      left: -2.5rem;
      width: 250px;
      height: 150px;
      background: var(--color-ui-secondary);
      border-radius: 20px;
      z-index: -1;
    }

    .img-top {
      grid-column: 2;
      grid-row: 1;
    }

    .img-bottom {
      grid-column: 2;
      grid-row: 2;
    }

    .empoyeesImg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: var(--border-image);
    }

    /* TEXT */

    h2 {
      font-size: xx-large;
      font-family: var(--font-heading);
      line-height: var(--space-2xl);
    }

    .title {
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    h2 {
      font-weight: 600;
    }

    /* CONTACT LIST */

    .ul-Expect {
      display: grid;
      gap: 3rem;
      padding: 0;
      margin-top: 3rem;
    }

    .ul-Expect li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 1rem;
      align-items: start;
    }
    li:has(+ p) {
      color: var(--color-text);
    }
    /* ICONS */

    .my-icon svg {
      width: 100%;
      height: 100%;
    }

    .ul-Expect li > div:first-child {
      border-radius: 33px;
      height: 50px;
      width: 50px;
      display: grid;
      place-items: center;
    }

    .phone {
      /* border: 5px solid #ffecbb;*/
      background: #ffecbb;
      color: #deaa27;
    }

    .clock {
      /* border: 5px solid #a4eda4;
      
      border-radius: 1rem; */
      color: #4eaf4e;
      background: #a4eda4;
    }

    .pin {
      color: #030712;

      background: #eaeaea;
    }

    /* MOBILE */

    @media (max-width: 868px) {
      .container {
        grid-template-columns: 1fr;
      }

      .empoyeesImg {
        order: -1;
      }

      .green::before {
        width: 200px;
        height: 120px;
        left: -1rem;
      }
    }
  }
</style>
