---
import experience from "@data/experience.json";
---

<section class="experience-container">
  <div class="inner-container">
    <div class="experience-info">
      <p class="eyebrow">{experience.eyebrow}</p>
      <h2 class="title">{experience.title}</h2>
      <p class="subtitle">{experience.subtitle}</p>
    </div>
    <div>
      <div class="animation-container">
        {
          experience.stats.map((experiences) => (
            <div class="stat-container">
              <div class="stat" style={`--percent: ${experiences.value}`} />
              <div class="label">{experiences.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  @layer components {
    .experience-container {
      background-color: var(--color-action);
      padding: var(--space-l-xl);

      .inner-container {
        display: grid;
        grid-template-columns: auto auto;

        .experience-info {
          display: flex;
          flex-direction: column;
          flex-wrap: wrap;
          gap: 1rem;

          .eyebrow {
            color: var(--color-text);
            text-transform: uppercase;
            font-size: var(--step-0);
          }

          .title {
            color: var(--color-text);
            font-size: var(--step-1);
          }

          .subtitle {
            color: var(--color-text);
            font-size: var(--step-0);
          }
        }
      }
    }

      .animation-container {
        display: flex;
        flex-direction: row;
        gap: 1rem;
        justify-content: center;
        padding: var(--space-s-l);
        font-weight: 600;
      }

      .stat-container {
        display: grid;
        justify-items: center;
        gap: 1rem;
        width: min(200px, 100% - 1rem);
      }

      @property --animatedNumber {
        syntax: "<number>";
        initial-value: 0;
        inherits: true;
      }

      .stat {
        --animatedNumber: 0;
        --percentage: calc(var(--animatedNumber) * 1%);
        --actual-percent: calc(var(--percent) * 1);
        --border-width: 5px;
        aspect-ratio: 1;
        width: min(150px, 100% - 0.2rem);
        border-radius: calc(Infinity * 1px);
        border: var(--border-width) solid #0000;
        content: "";
        background:
          radial-gradient(
              circle at 50% calc(var(--border-width) / 2),
              white calc(var(--border-width) / 2),
              #0000 0
            )
            border-box,
          linear-gradient(var(--color-action)) padding-box,
          conic-gradient(white var(--percentage), #daae3c 0) border-box;
        display: grid;
        container stat / inline-size;
        transition: --animatedNumber 2s;

        &:hover {
          --animatedNumber: var(--percent);
            animation-timeline: view();
            animation-range: entry 0% exit 100%;
        }
        

        &::before,
        &::after {
          grid-area: 1 / 1;
        }

        &::after {
          counter-reset: stat round(var(--animatedNumber));
          grid-area: 1 / 1;
          content: counter(stat) "%";
          place-self: center;
          font-size: var(--step-1);
        }

        &::before {
          content: "";
          aspect-ratio: 1;
          border-radius: calc(infinity * 1px);
          border: solid 3px white;
          offset-path: border-box;
          offset-distance: var(--actual-percent);
          offset-anchor: 50% calc(50% - var(--border-width) / 2);
          offset: border-box var(--percentage);
          width: calc(var(--border-width) * 4);
          background: var(--color-ui-primary);
        }
      }
  }
  @media (width < 800px) {
    .inner-container {
      display: flex;
      flex-direction: column;
    }

    @media (width < 500px) {
      .animation-container {
        display: flex;
        flex-wrap: wrap;
      }
    }
  }
</style>
