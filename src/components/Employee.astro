---
import employees from "@data/employees.json";
import DynamicImage from "@components/helpers/DynamicImage.astro";
---

<div class="employee-cards">
  {
    employees.map((id) => (
      <div class="employee-card">
        <div class="img-and-title">
          <DynamicImage
            imagePath={id.img}
            altText={id.name}
            class="image-card"
          />
          <p>{id.title}</p>
        </div>
        <h3 class="name">{id.name}</h3>
        <p class="description">{id.description}</p>

        <div class="socials">
          <a href="#">{id.social_links}</a>
          <a href="#">{id.social_links}</a>
        </div>
      </div>
    ))
  }
</div>

<style>
  @layer components {
    .employee-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(100px, 300px));
      grid-auto-rows: auto;
      gap: var(--element-spacing);
      margin: 0;
      justify-content: center;
    }

    .employee-card {
      padding: var(--card-padding-new);
      text-align: center;

      div {
        display: grid;
        grid-template-columns: [text-start] 1fr [text-end];
        grid-template-rows: 4fr [text-start] 1fr [text-end];

        img {
          grid-row: 1 / 3;
          grid-column: 1 / 3;
          border-radius: var(--border-image);
        }

        p {
          grid-area: text;
          text-align: end;
          padding-inline: var(--space-xs);
          padding-top: var(--space-2xs);
          margin: 0 var(--space-2xs) var(--space-2xs) auto;
          background-color: var(--color-ui-primary);
          color: var(--color-on-ui-primary);
          border-radius: var(--border-round);
        }
      }
    }
  }
</style>
