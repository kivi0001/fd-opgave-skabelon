---
// src/components/CoreValues.astro
import coreValues from "@data/coreValues.json";
import DynamicIcon from "@helpers/DynamicIcon.astro";
import ArrowRight from "@icons/arrow--right.svg";
---

<section class="value-container">
  <div class="value-header">
    <h2>{coreValues.eyebrow}</h2>
    <h1>{coreValues.title}</h1>
    <p>{coreValues.subtitle}</p>
    <a href={coreValues.button.link} class="button">{coreValues.button.text}</a>
  </div>

  <div class="value-cards">
    {
      coreValues.values.map((value) => (
        <div class="value-card">
          <DynamicIcon name={value.icon} class="value-icon" />
          <h3>{value.title}</h3>
          <p>{value.description}</p>
          <a href={value.link.url}>{value.link.text}</a>
          <ArrowRight width={22} height={22} class="arrowright-icon" />
        </div>
      ))
    }
  </div>
</section>

<style>
  section {
    background-color: var(--color-ui-primary);
    color: var(--color-on-ui-primary);
    display: grid;
    width: full-start full-end;

    .value-cards {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(0, 1fr);
      /* grid-template-columns: repeat(4, 1fr); */
      gap: 10px;

      > * {
        background-color: var(--color-surface-secondary);
        color: var(--color-text);
      }

      .value-icon {
        color: #f5f5f5;
        background-color: var(--color-ui-primary);
        padding: 10px;
        border-radius: 99px;
        box-sizing: content-box;
      }
    }
  }
</style>
