---
// src/components/CoreValues.astro
import coreValues from "@data/coreValues.json";
import DynamicIcon from "@helpers/DynamicIcon.astro";
import ArrowRight from "@icons/arrow--right.svg";
---

<section class="value-container">
  <!-- Indre container, der ikke fylder hele viewporten -->
  <div class="inner-container">
    <div class="value-info">
      <h3>{coreValues.eyebrow}</h3>
      <h2>{coreValues.title}</h2>
      <p>{coreValues.subtitle}</p>
      <a href={coreValues.button.link} class="button"
        >{coreValues.button.text}</a
      >
    </div>
    <div class="value-cards">
      {
        coreValues.values.map((value) => (
          <div class="value-card">
            <div class="value-icon">
              <DynamicIcon width={22} height={22} name={value.icon} />
            </div>
            <h3>{value.title}</h3>
            <p>{value.description}</p>
            <div class="arrow-link">
              <a href={value.link.url}>{value.link.text} </a>
              <ArrowRight width={15} height={15} class="arrowright-icon" />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @layer components {
    .value-container {
      background-color: var(--color-ui-primary);
      color: var(--color-on-ui-primary);
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full / -1;
      text-wrap: pretty;
    }

    .inner-container {
      container-type: inline-size;
      container-name: cards;
      grid-column: content;
      margin: var(--space-s) 0;
    }

    .value-info {
      display: grid;
      grid-template-columns: 3fr 1fr;
      padding: var(--space-s) 0;

      h3,
      h2,
      p {
        color: var(--color-on-ui-primary);
      }

      h3 {
        font-size: var(--space-s);
        text-transform: uppercase;
        grid-column: 1;
      }

      h2 {
        font-size: var(--space-l);
        grid-column: 1;
      }

      p {
        font-size: var(--space-s);
        grid-column: 1;
        margin: auto 0;
        max-width: 600px;
        hyphens: auto;
      }

      .button {
        width: fit-content;
        background-color: var(--color-on-ui-primary);
        color: var(--color-text);
        padding: 0.8rem 1rem;
        border-radius: var(--border-button);
        font-size: var(--space-s);
        grid-column: 4;
        margin: 0 0 20px 0;
      }
    }

    .value-cards {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-s);

      .arrow-link {
        display: flex;
        gap: 10px;

        a {
          text-decoration: none;
          color: var(--color-text);
          font-weight: 500;
        }
      }
    }

    .value-card {
      display: grid;
      align-content: first baseline;
      gap: 10px;
      background-color: var(--color-surface-secondary);
      border-radius: var(--border-card);
      padding: 2rem;

      h3,
      p,
      .arrowright-icon {
        color: var(--color-text);
      }

      .value-icon {
        color: #f5f5f5;
        background-color: var(--color-ui-primary);
        padding: 10px;
        border-radius: var(--border-icon);
        width: fit-content;

        svg {
          width: 22px;
          height: 22px;
        }

        .arrow-link {
          display: grid;
        }
      }
    }

    /* Container querien Reagerer på .inner-container's størrelse */
    @container cards (width < 900px) {
      .value-cards {
        grid-template-columns: 1fr 1fr;
      }

      p {
        font-size: var(--step--1);
      }
    }

    @container cards (width < 450px) {
      .value-cards {
        grid-template-columns: 1fr;
      }

      .value-info {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
      }
    }
  }
</style>
