<header>
  <div class="header-container">
    <h1>Ask<span>Experts</span></h1>
    <div class="nav-bar">
      <ul>
        <li><a href="index.astro">Home</a></li>
        <li><a href="case.astro">Case Study</a></li>
        <li><a href="team.astro">Team</a></li>
        <li><a href="about.astro">About</a></li>
      </ul>
    </div>
    <div class="button-nav">
      <button popovertarget="popup" class="header-button">LogIn</button>
    </div>
    <aside id="popup" popover="manual">
      <div class="popup-container">
        <h2>Dashboard Login</h2>
        <form class="form-container">
          <p>Email adress</p>
          <input type="email" placeholder="" />
          <p>Password</p>
          <input type="password" placeholder="" />
          <button type="submit" class="submit-button">Go to dashboard</button>
        </form>
      </div>
    </aside>
  </div>
  <div class="dropdown-container">
    <button class="dropdownbutton" id="dropdownbutton"
      >Menu<span>⌄</span></button
    >
    <div class="dropdown-content" id="dropdown-content">
      <a href="#">Home</a>
      <a href="#">Case Study</a>
      <a href="#">Team</a>
      <a href="#">About</a>
      <button class="close-button">X</button>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const dropbtn = document.getElementById("dropdownbutton");
    const dropdownContent = document.getElementById("dropdown-content");
    const dropdownContainer = document.querySelector(".dropdown-container");

    // Toggle dropdown ved klik på knappen
    dropbtn.addEventListener("click", (e) => {
      dropdownContent.classList.toggle("show");
    });

    // Lukker dropdown når man klikker på Luk knappen
    const closeBtn = document.querySelector(".close-button");
    closeBtn.addEventListener("click", () => {
      dropdownContent.classList.remove("show");
    });

    // Lukker dropdown når man klikker udenfor dropdown
    document.addEventListener("click", (e) => {
      if (!dropdownContainer.contains(e.target) && e.target !== dropbtn) {
        dropdownContent.classList.remove("show");
      }
    });
  });
</script>

<style>
  @layer components {
