        display: grid;
        grid-template-columns: 1fr auto 1fr;
        height: 80px;
        align-items: center;
      }

      h1 {
        color: var(--color-on-ui-primary);
        grid-column: 1;
        font-size: var(--step-2);

        span {
          color: var(--color-action);
        }
      }

      .dropdown-container {
        display: none;
        width: 100%;
        text-align: center;
        background-color: color-mix(
          in srgb,
          var(--color-dropdownmenu) 60%,
          transparent
        );
        backdrop-filter: blur(5px);
        position: relative;
        grid-column: full-start / -1;
      }

      .nav-bar {
        grid-column: 2;
      }
      ul {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        gap: var(--space-s-m);
        font-size: var(--step-0);
        padding: 0;
      }

      li:has(a) {
        list-style-type: none;

        a {
          text-decoration: none;
          color: var(--color-on-ui-primary);
        }
      }

      .button-nav {
        grid-column: 3;
        justify-self: end;
      }

      .header-button {
        background-color: var(--color-on-ui-primary);
        color: var(--color-text);
        padding: 0.3rem 1.5rem;
        border-radius: var(--border-button);
        font-size: var(--space-s);
        width: fit-content;
        border: none;
      }
    }

    [popovertarget] {
      anchor-name: --nav-btn;
    }
    [popover] {
      position: absolute;
      position-anchor: --nav-btn;
      position-area: bottom span-left;
      justify-self: anchor-center;
      position-try: flip-inline;
      background-color: var(--color-surface-secondary);
      border: none;
      box-shadow: 0px 8px 8px hsla(0, 0%, 0%, 0.151);
      border-radius: var(--border-s);
    }

    .popup-container {
      display: flex;
      flex-direction: column;
      width: fit-content;
      padding: 1rem 1.5rem;
      gap: 1rem;
      align-items: center;
      background-color: var(--color-surface-secondary);
      color: var(--color-text);

      h2 {
        font-size: var(--step-1);
      }

      p {
        color: var(--color-text);
        font-size: var(--step-0);
      }

      input {
        padding: var(--button-padding);
        border-radius: var(--border-round);
        font-size: var(--step-0);
        outline: none;
      }
    }

    form {
      display: grid;

      .submit-button {
        background-color: var(--color-action);
        color: var(--color-text);
        font-weight: 600;
        font-size: var(--step-0);
        border: none;
        border-radius: var(--border-round);
        padding: var(--button-padding);
        margin-block: 0.8rlh;
      }
    }

    @media (width < 550px) {
      .nav-bar ul {
        display: none;
      }

      .dropdown-container {
        display: block !important;
        grid-column: full-start / -1;
      }

      .dropdownbutton {
        background-color: var(--color-dropdownmen);
        color: var(--color-surface-tertiary);
        padding: 0.8rem 1.5rem;
        font-size: var(--step-2);
        border: none;
        border-radius: 4px;
        cursor: pointer;
        display: inline-block;
        position: relative;
        z-index: 1;

        span {
          color: var(--color-action);
          font-weight: 900;
          font-size: var(--step-3);
          padding-inline-start: 10px;
        }
      }

      .dropdown-content {
        display: none;
        position: absolute;
        top: 0;
