---
//@ts-nocheck
import DynamicImage from "@components/helpers/DynamicImage.astro";
import caseStudy from "@data/caseStudy.json";
import Button from "@components/Buttons.astro";
const { caseName, category, date, image, buttonLabel } = caseStudy.caseDetails;
---

<article>
  <header>
    <div class="header-container">
      <div class="headerimg">
        <DynamicImage imagePath={image} altText={caseName} />
      </div>
      <div class="case-details">
        <dl>
          <div>
            <dt>Case Name</dt>
            <dd>{caseName}</dd>
          </div>
          <div>
            <dt>Category</dt>
            <dd class="category">{category}</dd>
          </div>
          <div>
            <dt>Date</dt>
            <dd class="date">{date}</dd>
          </div>
        </dl>
        <div class="button">
          <Button theme="yellow">
            {buttonLabel}
          </Button>
        </div>
      </div>
    </div>
  </header>
  {
    caseStudy.sections.map((section) => (
      <section>
        {caseStudy.sections[0] === section ? (
          <h2>{section.title}</h2>
        ) : (
          <h3>{section.title}</h3>
        )}

        {Array.isArray(section.content) ? (
          <>
            {section.content.map((item) => (
              <p>{item}</p>
            ))}
          </>
        ) : (
          <p>{section.content}</p>
        )}
        {section.highlights && (
          <ul>
            {section.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
        )}
        {section.image && (
          <DynamicImage
            imagePath={section.image}
            altText={section.title}
            width={600}
            height={400}
          />
        )}
      </section>
    ))
  }
</article>

<style>
  @layer components {
    article {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full / -1;
      text-wrap: pretty;
    }

    header {
      grid-column: content;
    }

    .header-container {
      .headerimg img {
        border-radius: var(--border-s);
      }

      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }

    section {
      display: grid;
      gap: var(--space-s);
    }
  }
</style>
