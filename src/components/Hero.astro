---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
---

<section class="hero">
  <div class="main-hero-div">
    <div class="hero-content">
      <h1>Empowering Your Business Growth</h1>
      <p>
        Discover tailored strategies and expert insights to take your business
        to the next level. Let us help you navigate challenges and achieve
        sustainable success.
      </p>
      <a href="#0">Book a Meeting</a>
      <a href="#0">Learn More</a>
    </div>
    <Image class="hero-image" src={CEOImage} alt="CEO" />
  </div>
  <div class="service-cards-div">
    <Services />
  </div>
</section>

<style>
  /* Styles her */
  @layer components {
    .main-hero-div {
      background: var(--color-ui-primary);
      grid-column: full-start / -1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-row: 1 / 6;

      .hero-image {
        grid-column: 3 / 5;
        object-fit: contain;
      }
    }
    .hero {
      background-color: #f3f4f6;
      display: grid;
      /* grid-template-columns:
        [full-start] 1fr [content-left] minmax(0, 600px)
        [content-right] minmax(0, 600px) [content-end] 1fr [full-end]; */
      /*  grid-template-rows: 1fr 1fr 1fr 1fr; */

      .service-cards-div {
        /* grid-column: [content-left] / [content-end]; */
        grid-row: 5 / 7;
      }
    }

    .hero-content {
      grid-column: 1 / 3; /* FIRST TRY BACKGROUND GITTER */
      display: grid;
      grid-template-columns: repeat(3, 1fr);

      & > * {
        grid-column: 2 / 4;
      }

      /* background-image:
        linear-gradient(90deg, var(--color-action) 0.5px, transparent 0.5px),
        linear-gradient(var(--color-action) 0.5px, transparent 0.5px);
      background-size: 50px 50px;
      background-blend-mode: darken;
      background-color: rgba(0, 0, 0, 0.8); */

      background:
        radial-gradient(circle at 75% 50%, #0000, #000),
        conic-gradient(
            from 180deg at 1px 1px,
            hsl(from var(--color-action) h s l / 18%) 75%,
            #0000 0
          ) -1px -1px /
          60px 60px round round,
        #000;

      h1,
      p {
        color: var(--color-on-ui-primary);
      }
    }
  }
</style>
