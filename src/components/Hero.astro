---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
import Buttons from "@components/Buttons.astro";
---

<section class="hero">
  <div class="hero-content">
    <div>
      <h1>
        <div class="underline">
          <span class="underline-word">Empowering</span>
        </div>Your Business Growth
      </h1>
      <p>
        Discover tailored strategies and expert insights to take your business
        to the next level. Let us help you navigate challenges and achieve
        sustainable success.
      </p>
      <div class="buttons-div">
        <Buttons href="#0" theme="yellow">Book a Meeting</Buttons>
        <Buttons href="/about" theme="black">Learn More</Buttons>
      </div>
    </div>
  </div>
  <Image class="hero-image" src={CEOImage} alt="CEO" />
  <!--  </div> -->
  <div class="service-cards-div">
    <Services />
  </div>
</section>

<style>
  /* Styles her */
  @layer components {
    .main-hero-div {
      background: var(--color-ui-primary);
    }

    .hero {
      background-color: #f3f4f6;

      grid-column: full;
      display: grid;
      grid-row: 1 / span 3;
      grid-template-columns: subgrid;
      grid-template-rows: auto 1fr 1fr;
    }

    .hero-content {
      grid-column: full;
      grid-row: 1 / span 2;
      display: grid;
      grid-template-columns: subgrid;
      grid-template-rows: subgrid;

      > div {
        padding-block: 4rem 2rem;
        padding-right: var(--space-3xl);
        grid-column: content-start / middle;
        /*      display: grid;
        grid-template-columns: subgrid;

        > * + * {
          grid-column: content;
        } */
      }

      background:
        radial-gradient(circle at 75% 50%, #0000, #000),
        conic-gradient(
            from 180deg at 1px 1px,
            hsl(from var(--color-action) h s l / 18%) 75%,
            #0000 0
          ) -1px -1px /
          60px 60px round round,
        #000;

      h1 {
        color: var(--color-on-ui-primary);
      }
    }

    .underline {
      position: relative;
      display: inline-block;

      > span {
        position: relative;
        z-index: 1;
      }
    }
    .underline::before {
      content: "";
      position: absolute;
      bottom: 0.09rlh;
      right: 0;
      min-width: 100vw;
      min-height: 4px;
      background: linear-gradient(90deg, black, var(--color-surface-highlight));
      z-index: 0;
    }

    /*     .yellow-line-div{
      grid-column: full-start / middle;
      
      gap: .5rem;

      div {
        display: flex;
      justify-content: center;
      
      
      .yellow-h1 {
      position: relative;
      text-decoration: underline 4px var(--color-surface-highlight);

      anchor-name: --title;
      }

      }


    } */

    /*         .inner-div::before {
      content: "";
      position: absolute;

      inset-block-start: anchor(--title bottom);
      inset-inline-start: anchor(--title right);

      width: 11rem;
      /* calc(100vw - var(--content-width) / 2) */
    /*  height: 4px;
      bottom: 0;
      left: 0;
      top: 6.7rem;
      background: linear-gradient(90deg, black, var(--color-surface-highlight)); /* linear gradient (90deg, #000, yellow); */
    /*    }  */

    img {
      grid-column: middle / full-end;
      grid-row: 1 / 3;
      place-self: stretch;
      contain: size;
      object-fit: cover;
    }

    .buttons-div {
      padding-block: var(--space-l);
      display: flex;
      gap: 1rem;
    }

    .service-cards-div {
      grid-column: content;
      grid-row: 2 / 4;

      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      > * {
        flex: 1;
        padding: var(--card-padding-new);
      }
    }

    @media (width < 600px) {
      img {
        grid-column: content;
        grid-row: 1 / 2;
      }
      .hero-content div {
        grid-column: content;
        grid-row: 1 / 2;
        z-index: 1;

        p {
          color: var(--color-on-ui-primary);
        }
      }
    }
  }
</style>
